# ── Cargo Tracker — environment variables ─────────────────────────────
# Copy to .env and adjust. All values are optional; sensible defaults apply.

# Demo mode returns deterministic synthetic tracking data (no external calls).
# Default is true so the app works out of the box / on Vercel Hobby.
DEMO_MODE=true

# Per-source HTTP timeout in milliseconds (kept < Hobby 30s function limit).
TIMEOUT_MS=9000

# Retries per source on transient failure (0–2 recommended).
RETRIES=1

# Politeness delay between sequential lookups (ms).
RATE_LIMIT_DELAY_MS=600

# ── Optional live connectors ──────────────────────────────────────────
# CargoAI air-cargo API. Two access modes (auto-selected):
#   1) RapidAPI (recommended): set RAPIDAPI_KEY. Auth uses x-rapidapi-key /
#      x-rapidapi-host. Get the key at https://rapidapi.com (subscribe to
#      CargoAI "Air Cargo Track & Trace"). RAPIDAPI_HOST has a sane default.
#   2) Direct: set CARGOAI_API_KEY (Bearer token, commercial CargoAi account).
# If both are set, RapidAPI wins. If neither, the connector reports LOGIN_REQUIRED.
RAPIDAPI_KEY=
# RAPIDAPI_HOST=air-cargo-co2-track-and-trace.p.rapidapi.com
CARGOAI_API_KEY=
# CARGOAI_BASE_URL=   # optional override; derived per mode if left unset

# Optional Grok (xAI) for AI-assisted fallback parsing. If unset, a
# deterministic heuristic parser is used instead. Grok is never allowed to
# invent statuses or dates — it only structures already-fetched text (§10.1).
# The xAI API is OpenAI-compatible. Get a key at https://console.x.ai
XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# GROK_MODEL=grok-4.3

# Local server port (ignored on Vercel).
PORT=3001
